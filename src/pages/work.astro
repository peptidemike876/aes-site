---
import BaseLayout from '../layouts/BaseLayout.astro';

const events = [
  { name: "Ondo Summit", year: "2025", location: "New York City, USA", tagline: "250 invite-only institutional investors at Lincoln Center", slug: "/work/OndoSummit2025" },
  { name: "HederaCon", year: "2025", location: "Denver, USA", tagline: "1-day developer conference adjacent to ETH Denver, closing party at Meow Wolf", slug: "/work/HederaCon2025" },
  { name: "Chainlink SmartCon", year: "2024", location: "Hong Kong", tagline: "4-day flagship during Hong Kong Fintech Week — 2,000 attendees, 4 stages, Hacker House", slug: "/work/SmartCon2024" },
  { name: "Nearcon", year: "2024", location: "Bangkok, Thailand", tagline: "NEAR Protocol's flagship annual gathering for 1,500 attendees", slug: "/work/Nearcon2024" },
  { name: "Stacks Bitcoin Unleashed", year: "2024", location: "Singapore", tagline: "Half-day community event alongside Token2049 at the Fullerton Hotel", slug: "/work/StacksUnleashed2024" },
  { name: "Chainlink SmartCon", year: "2023", location: "Barcelona, Spain", tagline: "4 stages, 1,500 attendees, Hacker House — capped with a Barcelona closing night", slug: "/work/SmartCon2023" },
  { name: "Nearcon", year: "2023", location: "Lisbon, Portugal", tagline: "5 venues, 2,000 attendees, 30 sponsors — run through a natural disaster", slug: "/work/Nearcon2023" },
  { name: "Stacks Bitcoin Unleashed", year: "2023", location: "London, UK", tagline: "Protein Studios in Shoreditch — warehouse production, 2 stages, and a Bitcoin NFT gallery", slug: "/work/StacksUnleashed2023" },
  { name: "Stacks Bitcoin Unleashed", year: "2022", location: "Miami, USA", tagline: "Art Deco venue, NFT gallery, and an opening night in Wynwood — adjacent to Bitcoin Miami", slug: "/work/StacksUnleashed2022" },
  { name: "Solana Breakpoint", year: "2022", location: "Lisbon, Portugal", tagline: "Solana's global flagship developer conference", slug: "/work/Breakpoint2022" },
  { name: "Solana Saga Phone Launch", year: "2022", location: "New York City, USA", tagline: "Big reveal at the New York Times Center — less than 30 days to execute", slug: "/work/SagaPhone2022" },
  { name: "Nearcon", year: "2022", location: "Lisbon, Portugal", tagline: "Abandoned warehouse to crypto wonderland in 90 days — produced through a hurricane", slug: "/work/Nearcon2022" },
  { name: "Solana Breakpoint", year: "2021", location: "Lisbon, Portugal", tagline: "2,000 attendees across 5 venues — the first major event post-COVID", slug: "/work/Breakpoint2021" },
];
---
<BaseLayout
  title="Work — Amplified Event Strategy"
  description="Browse our portfolio of flagship crypto events — Ondo Summit, HederaCon, Chainlink SmartCon, Nearcon, Solana Breakpoint, and more. Produced across 6 continents since 2015."
  bodyClass="inner-page">


  <div class="container-fluid process-section">
    <div class="about-intro about-intro--reversed">
      <div class="about-intro-text">
        <div class="about-bg-text">OUR WORK</div>
        <div class="lg-text">Our Work</div>
        <div class="normal-text">
          <p>From intimate, invite-only summits to flagship developer conferences drawing thousands, every event we produce is built to the same standard — exceptional. Our portfolio spans four years, six continents, and the most respected names in the crypto industry.</p>
          <p>Each engagement is different, but our approach is not. We embed with our clients from concept to close, managing every detail so the experience speaks for itself.</p>
        </div>
      </div>
      <div class="about-intro-photo">
        <img src="/images/work3.png" alt="" />
      </div>
    </div>

  <div class="container-fluid portfolio-section">
    <div class="portfolio-grid">
      {events.slice(0, 3).map((event) => (
        <a href={event.slug} class="event-card">
          <div class="event-card-photo"></div>
          <div class="event-card-info">
            <div class="event-card-meta">{event.location} · {event.year}</div>
            <div class="event-card-name">{event.name}</div>
            <div class="event-card-tagline">{event.tagline}</div>
            <div class="event-card-cta">View Event →</div>
          </div>
        </a>
      ))}
    </div>
    <div class="portfolio-divider"><span></span></div>
    <div class="portfolio-grid portfolio-grid--five">
      {events.slice(3).map((event) => (
        <a href={event.slug} class="event-card event-card--sm">
          <div class="event-card-photo"></div>
          <div class="event-card-info">
            <div class="event-card-meta">{event.location} · {event.year}</div>
            <div class="event-card-name">{event.name}</div>
            <div class="event-card-tagline">{event.tagline}</div>
            <div class="event-card-cta">View Event →</div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="container-fluid world-map-section">
    <div class="world-map-heading">Our Stage Is Global</div>
    <div class="world-map-inner">
      <img src="/images/worldmap2.png" alt="World map" class="world-map-img" />

      <!-- New York City -->
      <div class="map-dot" style="left: 25.5%; top: 41%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup">
          <div class="map-popup-city">New York City</div>
          <a href="/work/OndoSummit2025" class="map-popup-event">Ondo Summit 2025</a>
          <a href="/work/SagaPhone2022" class="map-popup-event">Solana Saga Phone Launch 2022</a>
        </div>
      </div>

      <!-- Denver -->
      <div class="map-dot" style="left: 19.5%; top: 42%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup">
          <div class="map-popup-city">Denver, USA</div>
          <a href="/work/HederaCon2025" class="map-popup-event">HederaCon 2025</a>
        </div>
      </div>

      <!-- Miami -->
      <div class="map-dot" style="left: 24.3%; top: 49%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup">
          <div class="map-popup-city">Miami, USA</div>
          <a href="/work/StacksUnleashed2022" class="map-popup-event">Stacks Bitcoin Unleashed 2022</a>
        </div>
      </div>

      <!-- London -->
      <div class="map-dot" style="left: 46.8%; top: 32%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup map-popup--left">
          <div class="map-popup-city">London, UK</div>
          <a href="/work/StacksUnleashed2023" class="map-popup-event">Stacks Bitcoin Unleashed 2023</a>
        </div>
      </div>

      <!-- Lisbon -->
      <div class="map-dot" style="left: 44.5%; top: 41%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup map-popup--left">
          <div class="map-popup-city">Lisbon, Portugal</div>
          <a href="/work/Nearcon2023" class="map-popup-event">Nearcon 2023</a>
          <a href="/work/Breakpoint2022" class="map-popup-event">Solana Breakpoint 2022</a>
          <a href="/work/Nearcon2022" class="map-popup-event">Nearcon 2022</a>
          <a href="/work/Breakpoint2021" class="map-popup-event">Solana Breakpoint 2021</a>
        </div>
      </div>

      <!-- Barcelona -->
      <div class="map-dot" style="left: 47.2%; top: 39%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup map-popup--left">
          <div class="map-popup-city">Barcelona, Spain</div>
          <a href="/work/SmartCon2023" class="map-popup-event">Chainlink SmartCon 2023</a>
        </div>
      </div>

      <!-- Hong Kong -->
      <div class="map-dot" style="left: 78.6%; top: 51%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup map-popup--left">
          <div class="map-popup-city">Hong Kong</div>
          <a href="/work/SmartCon2024" class="map-popup-event">Chainlink SmartCon 2024</a>
        </div>
      </div>

      <!-- Bangkok -->
      <div class="map-dot" style="left: 74.7%; top: 57%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup map-popup--left">
          <div class="map-popup-city">Bangkok, Thailand</div>
          <a href="/work/Nearcon2024" class="map-popup-event">Nearcon 2024</a>
        </div>
      </div>

      <!-- Singapore -->
      <div class="map-dot" style="left: 75.5%; top: 63%;">
        <div class="map-dot-ring"></div>
        <div class="map-dot-ring map-dot-ring--2"></div>
        <div class="map-dot-ring map-dot-ring--3"></div>
        <div class="map-dot-core"></div>
        <div class="map-popup map-popup--left">
          <div class="map-popup-city">Singapore</div>
          <a href="/work/StacksUnleashed2024" class="map-popup-event">Stacks Bitcoin Unleashed 2024</a>
        </div>
      </div>

    </div>
  </div>

</BaseLayout>
