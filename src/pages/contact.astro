---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Amplified Event Strategy" bodyClass="inner-page">

  <header class="container-fluid header">
    <div class="row">
      <div class="col">
        <div class="extra-lg-text">
          <span>Let's Build</span><br />
          <span>Something</span><br />
          <span>Remarkable.</span>
        </div>
      </div>
    </div>
  </header>

  <div class="container-fluid contact-section">
    <div class="contact-section-inner">

      <div class="contact-photos">
        <div class="contact-photo-item" style="background-image: url('/images/work4.png')"></div>
        <div class="contact-photo-item" style="background-image: url('/images/work6.png')"></div>
      </div>

      <div class="contact-details">
        <div class="contact-block">
          <div class="contact-label">Email</div>
          <div class="contact-value">
            <a href="mailto:hello@amplifiedeventstrategy.com">hello@amplifiedeventstrategy.com</a>
          </div>
        </div>
        <div class="contact-block">
          <div class="contact-label">Based In</div>
          <div class="contact-value">New York, USA</div>
        </div>
        <div class="contact-block">
          <div class="contact-label">How We Work</div>
          <div class="contact-value contact-value--body">
            We work entirely by referral. Every client has come to us through a trusted introduction — and every event we produce speaks for itself. If you've found us, let's talk.
          </div>
        </div>
        <div class="contact-cta">
          <a href="mailto:hello@amplifiedeventstrategy.com" class="cr-btn white ex-padding">Send Us a Note →</a>
        </div>
      </div>

    </div>
  </div>

</BaseLayout>
