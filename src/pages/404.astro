---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — Amplified Event Strategy" bodyClass="inner-page">

  <header class="container-fluid header">
    <div class="row">
      <div class="col">
        <div class="extra-lg-text">
          <span>404.</span><br />
          <span>Page Not</span><br />
          <span>Found.</span>
        </div>
      </div>
    </div>
  </header>

  <div class="container-fluid" style="padding: 4rem 6rem 8rem;">
    <p style="font-family: 'montserrat', sans-serif; font-size: 1.1rem; color: #fff; margin-bottom: 3rem; max-width: 40rem;">
      The page you're looking for doesn't exist. It may have moved, or you may have followed a broken link.
    </p>
    <a href="/" class="cr-btn white ex-padding">← Back to Home</a>
  </div>

</BaseLayout>
