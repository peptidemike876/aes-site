---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Chainlink SmartCon 2024 — AES" bodyClass="inner-page">

  <div class="container-fluid event-hero">
    <div class="event-hero-small-inner">
      <div class="event-location">Hong Kong</div>
      <div class="event-title">Chainlink<br />SmartCon<br />2024</div>
      <div class="event-tagline">
        A 4-day flagship event during Hong Kong Fintech Week — 2,000 attendees, 4 stages of content, and a 2-day Hacker House for developers. One of the most logistically ambitious productions we've delivered.
      </div>
    </div>
  </div>

  <div class="container-fluid event-gallery">
    <div class="event-gallery-inner">
      <div class="gallery-grid gallery-grid--two">
        <div class="gallery-placeholder" style="background-image: url('/images/work3.png')"></div>
        <div class="gallery-placeholder" style="background-image: url('/images/work5.png')"></div>
      </div>
    </div>
  </div>

  <div class="container-fluid event-back">
    <div class="event-back-inner">
      <a href="/work" class="cr-btn white ex-padding">← Back to All Events</a>
    </div>
  </div>

</BaseLayout>
